{
  "manifest_version": 3,
  "name": "Tabbit for Firefox - Automatic Tab Grouping",
  "version": "1.0.0",
  "description": "Automatic tab grouping — groups new tabs with the tab that opened them. Configurable naming, max group size, custom rules, blacklist, and more.",
  "browser_specific_settings": {
    "gecko": {
      "id": "tabbit@thevirtualpanda",
      "strict_min_version": "139.0"
    }
  },
  "permissions": ["tabs", "tabGroups", "storage"],
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Tabbit",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "homepage_url": "https://github.com/bunger/tabbit-firefox"
}
